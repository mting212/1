# MeetFlow Production Environment Variables
# Copy this file to .env on your production server and fill in real values.
# NEVER commit .env to git!

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://meetflow:CHANGE_ME@postgres:5432/meetflow
POSTGRES_USER=meetflow
POSTGRES_PASSWORD=CHANGE_ME_TO_RANDOM_32_CHARS
POSTGRES_DB=meetflow

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Authentication (NextAuth.js) ───────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_TO_RANDOM_64_CHARS
AUTH_URL=https://meetflow.dev

# ── OAuth Providers ────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# ── Video Conferencing ─────────────────────────────────────
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# ── Email (SMTP) ───────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=bookings@meetflow.dev

# ── AI (Optional, Phase 4) ─────────────────────────────────
DEEPSEEK_API_KEY=

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=info

# ── gRPC ───────────────────────────────────────────────────
GRPC_SCHEDULER_ADDR=scheduler:9090

# ── Node ───────────────────────────────────────────────────
NODE_ENV=production
